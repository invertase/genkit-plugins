{
  "name": "@genkitx-json-render/example-agentic-chat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c magenta,cyan \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch --env-file-if-exists=.env server/index.ts",
